generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  name             String?
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscription  Subscription?
  bots          Bot[]
  portfolios    Portfolio[]
  notifications Notification[]
  botTemplates  BotTemplate[]

  @@map("users")
}

model Bot {
  id           String    @id @default(uuid())
  name         String
  description  String?
  symbol       String
  status       BotStatus @default(STOPPED)
  userId       String
  templateId   String?
  isPublic     Boolean   @default(false)
  shareSlug    String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template         BotTemplate?       @relation(fields: [templateId], references: [id])
  strategyConfig   StrategyConfig?
  trades           Trade[]
  logs             BotLog[]
  executionSession ExecutionSession?
  portfolioId      String?
  lastRunAt        DateTime?
  lastSignalAt     DateTime?

  portfolio        Portfolio? @relation(fields: [portfolioId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([templateId])
  @@index([portfolioId])
  @@index([isPublic, createdAt])
  @@index([status, lastRunAt])
  @@map("bots")
}

model Portfolio {
  id        String   @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bots  Bot[]

  @@index([userId])
  @@map("portfolios")
}

model Instrument {
  id                 String              @id @default(uuid())
  symbol             String              @unique
  displayName        String
  assetClass         InstrumentAssetClass
  marketType         InstrumentMarketType
  baseAsset          String?
  quoteCurrency      String
  exchange           String
  dataSource         String
  sourceSymbol       String?
  supportedIntervals Json
  pricePrecision     Int
  quantityPrecision  Int
  status             InstrumentStatus    @default(ACTIVE)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([isActive])
  @@index([isActive, status])
  @@index([assetClass, marketType])
  @@map("instruments")
}

enum BotStatus {
  RUNNING
  STOPPED
  PAUSED
  ERROR
}

enum InstrumentAssetClass {
  CRYPTO
  COMMODITY
}

enum InstrumentMarketType {
  SPOT
  CFD
}

enum InstrumentStatus {
  ACTIVE
  MAINTENANCE
  DISABLED
}

model StrategyConfig {
  id           String   @id @default(uuid())
  botId        String   @unique
  strategy     String
  params       Json
  builderConfig Json?   @map("builder_config") // Visual builder JSON; takes precedence over raw params when present
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("strategy_configs")
}

model Trade {
  id          String      @id @default(uuid())
  botId       String
  symbol      String
  side        TradeSide
  quantity    Float
  price       Float
  totalValue  Float
  status      TradeStatus @default(PENDING)
  executedAt  DateTime?
  openReason      String?
  openExplanation Json?
  exitPrice       Float?
  realizedPnl     Float?
  stopLoss        Float?
  takeProfit      Float?
  entryFee        Float?
  exitFee         Float?
  slippageBps     Int?
  netPnl          Float?
  closedAt        DateTime?
  closeReason     String?
  closeExplanation Json?
  createdAt   DateTime    @default(now())

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@index([botId, status, createdAt])
  @@index([botId, symbol, createdAt])
  @@index([createdAt, botId])
  @@index([botId, closedAt])
  // Retention job: batch-delete closed trades by closedAt + status + createdAt
  @@index([closedAt, status, createdAt])
  @@map("trades")
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  EXECUTED
  CANCELLED
  FAILED
  CLOSED
}

model BotLog {
  id        String   @id @default(uuid())
  botId     String
  level     LogLevel
  category  String   @default("system")
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  deletedAt DateTime?

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  // Existing: query logs for a bot (active records)
  @@index([botId, createdAt])
  // Existing: filter logs by level
  @@index([level, createdAt])
  // Retention job: partial covering index — only active rows (deletedAt IS NULL).
  // See migration for the PostgreSQL partial index definition.
  @@index([deletedAt])
  @@map("bot_logs")
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  DEBUG
}

model ExecutionSession {
  id             String   @id @default(uuid())
  botId          String   @unique
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  totalTrades    Int      @default(0)
  profitLoss     Float    @default(0)
  initialBalance Float
  currentBalance Float

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  // Retention job: batch-delete ended sessions by endedAt
  @@index([endedAt])
  @@map("execution_sessions")
}

model BotTemplate {
  id           String   @id @default(uuid())
  userId       String?
  name         String
  description  String?
  strategy     String
  params       Json
  isDefault    Boolean  @default(false)
  isSystem     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bots  Bot[]

  @@index([userId])
  @@index([isSystem, isDefault])
  @@map("bot_templates")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  botId     String?
  tradeId   String?
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  // Retention job: batch-delete read notifications — isRead leads (already filtered to isRead=true)
  @@index([isRead, createdAt])
  @@map("notifications")
}

enum NotificationType {
  BOT_STARTED
  BOT_STOPPED
  BOT_ERROR
  TRADE_OPENED
  TRADE_CLOSED
  STOP_LOSS_HIT
  TAKE_PROFIT_HIT
}

model Backtest {
  id        String   @id @default(uuid())
  userId    String
  symbol    String
  interval  String
  strategy  String
  params    Json
  fromDate  DateTime
  toDate    DateTime
  status    BacktestStatus @default(PENDING)
  metrics   Json?
  trades    Json?
  equityCurve Json?
  error     String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  // Retention job: batch-delete completed/failed backtests — createdAt leads (date cutoff is high-selectivity)
  @@index([createdAt, status])
  @@map("backtests")
}

enum BacktestStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Billing ─────────────────────────────────────────────────────────────────────

model Subscription {
  id                   String     @id @default(uuid())
  userId              String     @unique
  plan                Plan       @default(FREE)
  status              SubStatus  @default(ACTIVE)
  currentPeriodEnd    DateTime
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum Plan {
  FREE
  PRO
  PREMIUM
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}
