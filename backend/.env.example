# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_bot?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional: isolate BullMQ queues (e.g. second local backend) — Redis logical DB 0–15
# REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Admin (comma-separated emails allowed to access /admin/* APIs)
# ADMIN_EMAILS=admin@example.com

# Server
PORT=3001
NODE_ENV=development

# CORS
# CORS allowlist (comma-separated). Do not use "*" when `credentials: true`.
CORS_ORIGIN=http://localhost:3000

# Market data execution cadence (optional)
# MARKET_DATA_TICK_MS=2000
# MARKET_DATA_HISTORY=200
# MARKET_DATA_PROVIDER=binance
# BINANCE_MARKET_DATA_URL=https://api.binance.com
# BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Instrument catalog sync (optional)
# INSTRUMENT_SYNC_PROVIDER=binance
# INSTRUMENT_SYNC_INTERVAL_MS=21600000
# BINANCE_METADATA_URL=https://api.binance.com

DATA_RETENTION_CRON=0 3 * * *
LOG_RETENTION_INFO_DEBUG_DAYS=7
LOG_RETENTION_WARNING_ERROR_DAYS=90
TRADE_RETENTION_DAYS=90
NOTIFICATION_RETENTION_DAYS=30
BACKTEST_RETENTION_DAYS=90
EXECUTION_SESSION_RETENTION_DAYS=90
RETENTION_BATCH_SIZE=1000
DATA_RETENTION_MAX_RETRIES=1
